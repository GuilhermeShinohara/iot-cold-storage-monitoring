{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Temperatura (°C)",
      "datasource": {
        "type": "influxdb",
        "uid": "INFLUXDB"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "query": "SELECT mean(\"temperatura\") FROM \"cadeia_frio\" WHERE $timeFilter GROUP BY time($__interval) fill(null)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        }
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Umidade (%)",
      "datasource": {
        "type": "influxdb",
        "uid": "INFLUXDB"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "B",
          "query": "SELECT mean(\"umidade\") FROM \"cadeia_frio\" WHERE $timeFilter GROUP BY time($__interval) fill(null)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
